    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@supabase/supabase-js": "^2.38.5",
    "@tanstack/react-query": "^5.100.3",
    "clsx": "^2.1.0",
    "dotenv": "^17.4.2",
    "emoji-picker-react": "^4.18.0",
