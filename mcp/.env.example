# Supabase credentials — required for MCP server to access database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# MCP server configuration
# Transport mode: "stdio" for Claude Code local MCP, "http" for remote HTTP transport
MCP_TRANSPORT=http

# Port for local HTTP mode (ignored in Vercel/Railway — they set PORT automatically)
PORT=3333

# Public app URL — used to build correct public_url in responses (custom slug pages live at /s/{slug})
APP_URL=https://mylogblock.vercel.app

# API key — all /mcp requests must send: Authorization: Bearer <this value>
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_API_KEY=your-secret-api-key-here
